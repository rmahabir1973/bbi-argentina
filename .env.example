# ─────────────────────────────────────────────────────────────
# BBI Argentina — Environment Variables
# Copy this file to .env.local for local development
# All production secrets are set in Railway environment panel
# ─────────────────────────────────────────────────────────────

# ── Payload CMS ──────────────────────────────────────────────
PAYLOAD_SECRET=change-me-to-a-random-64-char-string

# ── Neon Postgres (Railway auto-injects DATABASE_URL too) ────
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# ── Cloudflare R2 / S3-Compatible Storage ───────────────────
S3_BUCKET=bbi-argentina-media
S3_REGION=auto
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN URL for media delivery (R2 custom domain or public URL)
NEXT_PUBLIC_S3_HOSTNAME=https://media.bbiargentina.com

# ── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_DEFAULT_FROM=noreply@bbiargentina.com
RESEND_TEAM_EMAIL=team@bbiargentina.com

# ── Next.js ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.bbiargentina.com

# ── Optional CRM sync (set to enable, leave unset to skip) ───
# HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxx
# PIPEDRIVE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CRM_PROVIDER=hubspot   # or: pipedrive

# ── Railway (injected automatically) ────────────────────────
# PORT=3000
# RAILWAY_ENVIRONMENT=production
